<!DOCTYPE html>
<html>
<head>
    <title>Registration Form</title>
</head>
<body text="orange">
    
    
    <form method="get">

        <table bgcolor="#373f4a">
            <tr bgcolor="red">
                 <th colspan=2 align="left">Sign Up</th>
    
            </tr>

            <tr>
                <td>First Name</td>
                <td>
                    <input type="text" name="txtfirstname" placeholder="Enter First Name">
                </td>
            </tr>

            <tr>
                <td>Last Name</td>
                <td>
                    <input type="text" name="txtlastname" placeholder="Enter Last Name">
                </td>
            </tr>

            <tr>
                <td>Date of Birth</td>
                <td>
                    <input type="date"name="DOB">
                </td>
            </tr>

            <tr>
                <td>Gender</td>
                <td>
                    <input type="radio" name="gender" value="male> Male
                    <input type="radio" name="gender"value="female> Female
                </td>
            </tr>

            <tr>
                <td>Country</td>
                <td>
                    <select>
                        <option>Country</option>
                        <option>India</option>
                        <option>Nepal</option>
                        <option>Bangladesh</option>
                    </select>
                </td>
            </tr>

            <tr>
                <td>E-mail</td>
                <td>
                    <input type="email"name="email" placeholder="Enter E-mail">
                </td>
            </tr>

            <tr>
                <td>Phone</td>
                <td>
                    <input type="number"name="mobile" placeholder="Enter Phone">
                </td>
            </tr>

            <tr>
                <td>Password</td>
                <td>
                    <input type="password"name="pass">
                </td>
            </tr>

            <tr>
                <td>Confirm Password</td>
                <td>
                    <input type="password"name="confirmpass">
                </td>
            </tr>

            <tr>
                <td colspan="2" align="right">
                    <input type="checkbox"name="check"value="term">
                    I Agree to the Terms of use
               
                </td>
                <tr>
                    <td align="right"colspan="2" bgcolor="orange">
                        <input type="submit" value="Submit">
                    <input type="reset" value="Cancel">
                
                    </td>
                </tr>
                
            </tr>

            <tr>
                
                    
            </tr>

        </table>

    </form>
   

</body>
</html>
