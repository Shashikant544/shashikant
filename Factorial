<body>

<form method="post">
    Enter Number:
    <input type="number" name="num">
    <input type="submit" value="Factorial">
</form>

<?php
if(isset($_POST['num']))
{
    $n = $_POST['num'];
    $fact = 1;

    for($i=1; $i<=$n; $i++)
    {
        $fact *= $i;
    }

    echo "Factorial = ".$fact;
}
?>

