if(isset($_POST['prime'])){
    $n = $_POST['num'];
    $count = 0;

    for($i=1;$i<=$n;$i++){
        if($n % $i == 0){
            $count++;
        }
    }

    if($count==2)
        echo "$n is Prime Number";
    else
        echo "$n is Not Prime Number";
}
