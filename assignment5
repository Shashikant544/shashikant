<!DOCTYPE html>
<html>
<head>
    <title>User Form</title>
</head>
<body bgcolor="#a7ff85">
  
     
          <form method="get">
               <fieldset>
                   <legend align="center">
                       <h2>USER FORM
                       </h2>
                       </legend>  
                   
              <b>
<table bgcolor="#00ff00" width=100% height=600px>

<tr>
    <td>FIRST NAME</td>
    <td><input type="text" name="fname"></td>
</tr>

<tr>
    <td>PASSWORD</td>
    <td><input type="password" name="pass"></td>
</tr>

<tr>
    <td>GENDER</td>
    <td>
        <input type="radio" name="gender"value="male"> Male
        <input type="radio" name="gender"value="female"> Female
    </td>
</tr>

<tr>
    <td>ADDRESS</td>
    <td>
        <textarea rows="4" cols="20"></textarea>
    </td>
</tr>

<tr>
    <td>D.O.B</td>
    <td>
        <input type="date" name="DOB">
    </td>
</tr>

<tr>
    <td>SELECT GAMES</td>
    <td>
        <input type="checkbox"name="check1" value="hockey"> Hockey
        <input type="checkbox"name="check2 value="Football> Football
        <input type="checkbox"name="check3"value="cricket"> Cricket
        <input type="checkbox"name="check4"value="volleyball"> VolleyBall
    </td>
</tr>

<tr>
    <td>MARITAL STATUS</td>
    <td>
        <input type="radio" name="status"value="married> Married
        <input type="radio" name="status"value="unmarried"> Unmarried
    </td>
</tr>

</tr>

<tr>
    <td colspan="2" align="center">
        <input type="submit" value="Submit">
        <input type="reset" value="Reset">
    </td>
</tr>
  
<tr>
    <td colspan="2"align=center>
        <input type="checkbox"> I accept this agreement
    </td>

</table>

</form>
  </b>
  </fieldset>

</body>
</html>
